# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# Uncomment and set below to use a custom API endpoint (e.g. ModelLab)
# ANTHROPIC_BASE_URL=https://api.modellab.com/v1
# ── Optional: AI Media Generation ─────────────────────────────────────────────
# Set MOCK_MEDIA_APIS=False in config.py and provide these keys
# to generate real images and videos instead of structured prompts.

OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE     # DALL-E 3 image generation
MODELSLAB_API_KEY=YOUR_MODELSLAB_KEY_HERE   # ModelsLab image generation
RUNWAY_API_KEY=YOUR_RUNWAY_KEY_HERE         # Runway ML Gen-3 video generation
PIKA_API_KEY=YOUR_PIKA_KEY_HERE             # Pika Labs 1.5 video generation

# ── Optional: Scraping (live viral data) ──────────────────────────────────────
# If you want to pull real Instagram data instead of using simulation
APIFY_API_TOKEN=YOUR_APIFY_TOKEN_HERE
